{
  "name": "monkey-cook",
  "displayName": "monkey-cook",
  "description": "This extension help developpers to follow workflow before develop and push new broken features",
  "version": "0.0.9",
  "publisher": "monkey-cook",
  "engines": {
    "vscode": ">=1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:monkeyCookView",
    "onCommand:monkey-cook.createWorkflow",
    "onCommand:monkey-cook.startWorkflow",
    "onCommand:monkey-cook.openWorkflowView",
    "onCommand:monkey-cook.addCategory",
    "onCommand:monkey-cook.addStep"
  ],
  "main": "./dist/extension.js",
  "icon": "images/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "monkey-cook.createWorkflow",
        "title": "Monkey Cook: Create Workflow"
      },
      {
        "command": "monkey-cook.startWorkflow",
        "title": "Monkey Cook: Start Workflow"
      },
      {
        "command": "monkey-cook.openWorkflowView",
        "title": "Monkey Cook: Ouvrir l'onglet Workflow"
      },
      {
        "command": "monkey-cook.addCategory",
        "title": "Monkey Cook: Ajouter une catégorie"
      },
      {
        "command": "monkey-cook.addStep",
        "title": "Monkey Cook: Ajouter une étape"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "monkey-cook",
          "title": "Monkey Cook",
          "icon": "images/icon_white.png"
        }
      ]
    },
    "views": {
      "monkey-cook": [
        {
          "id": "monkeyCookView",
          "name": "Monkey Cook",
          "type": "webview"
        }
      ]
    },
    "explorer": [
      {
        "id": "monkeyCookView",
        "name": "Monkey Cook",
        "type": "webview"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "monkey-cook.openWorkflowView",
          "when": "view == monkeyCookView"
        }
      ],
      "view/item/context": [
        {
          "command": "monkey-cook.addStep",
          "when": "view == monkeyCookView && viewItem == category"
        }
      ]
    }
  },
  "scripts": {
    "copy-codicons": "node -e \"const fs=require('fs');const p=require('path');const d=p.join(process.cwd(),'media','codicons');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join(process.cwd(),'node_modules','@vscode','codicons','dist','codicon.css'),p.join(d,'codicon.css'));fs.copyFileSync(p.join(process.cwd(),'node_modules','@vscode','codicons','dist','codicon.ttf'),p.join(d,'codicon.ttf'));\"",
    "vscode:prepublish": "npm run package",
    "compile": "npm run copy-codicons && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run copy-codicons && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": ">=1.90.0",
    "@vscode/codicons": "^0.0.44",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
